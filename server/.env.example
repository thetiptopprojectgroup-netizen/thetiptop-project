# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/thetiptop

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# OAuth Google (connexion + création de compte)
# Console : https://console.cloud.google.com/apis/credentials → Type "Application Web"
# URI de redirection : BACKEND_URL/api/auth/google/callback (ex. http://localhost:5000/api/auth/google/callback)
# Origines JavaScript : CLIENT_URL (ex. http://localhost:3000)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Facebook (optionnel)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# URLs (OAuth callbacks, redirection après login)
BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Email Configuration (pour les notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# EmailJS (newsletter — emails depuis le serveur via REST API)
# Compte : https://www.emailjs.com/ — Service email + modèles + clés API (Account → API keys)
EMAILJS_SERVICE_ID=service_85ig8ef
EMAILJS_PUBLIC_KEY=3JGnaFOAoe2uCHoN9
# Clé privée recommandée pour les appels serveur (réduit les abus)
EMAILJS_PRIVATE_KEY=6zhpXKcEp_BNzmOsfxZ6I
# IDs des modèles (Email → Templates) : bienvenue + désinscription (optionnel si absent)
EMAILJS_TEMPLATE_NEWSLETTER_WELCOME=template_nqb8mem
EMAILJS_TEMPLATE_NEWSLETTER_GOODBYE=

# Contest Configuration
CONTEST_START_DATE=2026-03-01
CONTEST_END_DATE=2026-03-30
CLAIM_END_DATE=2026-04-29
MAX_TICKETS=500000
