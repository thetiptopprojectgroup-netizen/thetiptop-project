# Copier vers vdev.env sur le serveur (ne pas committer les secrets).
# COMPOSE_PROJECT_NAME isole les volumes MongoDB par environnement.
COMPOSE_PROJECT_NAME=thetiptop-vdev

STACK_NAME=vdev

# Règle Traefik (Host) — un seul FQDN pour vdev.
# Les backticks ` sont obligatoires (syntaxe Traefik). Pas de guillemets « typographiques ».
# Si https://vdev… affiche « 404 page not found » (Traefik) : secret VDEV_ENV_FILE sans CRLF
# (éditer sous Linux ou « LF » dans l’éditeur), puis redéployer. Vérifier DNS → IP du VPS.
TRAEFIK_HOST_RULE=Host(`vdev.dsp5-archi-o22a-15m-g3.fr`)

# Registre Harbor : projet GitHub « vdev » (créer le projet vdev dans Harbor)
REGISTRY=harbor.dsp5-archi-o22a-15m-g3.fr/vdev

# Renseigné par la CI au déploiement (SHA du commit)
IMAGE_TAG=replace-me

MONGO_ROOT_PASSWORD=change-me-root
MONGO_USER=thetiptop
MONGO_PASSWORD=thetiptop123

JWT_SECRET=change-me-jwt-vdev
# Doit être l’URL du site pour cette env (liens email newsletter / OAuth)
CLIENT_URL=https://vdev.dsp5-archi-o22a-15m-g3.fr
# Même valeur que CLIENT_URL si l’API est sous /api sur le même host (voir docker-compose.stack.yml)
BACKEND_URL=https://vdev.dsp5-archi-o22a-15m-g3.fr

# OAuth Google — mêmes clés qu’en vprod si un seul client OAuth (redirects multiples dans Google Cloud)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# EmailJS — newsletter (même compte possible pour vdev / preprod / prod ; liens désinscription = CLIENT_URL)
EMAILJS_SERVICE_ID=service_85ig8ef
EMAILJS_PUBLIC_KEY=3JGnaFOAoe2uCHoN9
EMAILJS_PRIVATE_KEY=6zhpXKcEp_BNzmOsfxZ6I
EMAILJS_TEMPLATE_NEWSLETTER_WELCOME=template_nqb8mem
EMAILJS_TEMPLATE_NEWSLETTER_GOODBYE=
# Attestation remise lot (employé) — server/docs/emailjs-template-prize-delivered.html
EMAILJS_TEMPLATE_PRIZE_DELIVERED=template_keszo9j

# Nombre de codes générés au tout premier déploiement (seedTickets.js). Si la collection codes
# contient déjà des entrées, le déploiement ne régénère rien. Défaut si vide : 500000.
# Exemple dev plus léger : SEED_TICKET_COUNT=5000
# SEED_TICKET_COUNT=5000

# Comptes de démo : créés automatiquement en fin de job GitHub Actions (createAdmin.js + seedTickets).
# Par défaut : admin@thetiptop.fr / Admin123! — exécution manuelle si besoin :
# docker compose -f infra/deploy/docker-compose.stack.yml --env-file infra/deploy/env/vdev.env exec api node src/scripts/createAdmin.js
# docker compose -f infra/deploy/docker-compose.stack.yml --env-file infra/deploy/env/vdev.env exec api node src/scripts/seedTickets.js
