# Copier vers vdev.env sur le serveur (ne pas committer les secrets).
# COMPOSE_PROJECT_NAME isole les volumes MongoDB par environnement.
COMPOSE_PROJECT_NAME=thetiptop-vdev

STACK_NAME=vdev

# Règle Traefik (Host) — un seul FQDN pour vdev.
# Les backticks ` sont obligatoires (syntaxe Traefik). Pas de guillemets « typographiques ».
# Si https://vdev… affiche « 404 page not found » (Traefik) : secret VDEV_ENV_FILE sans CRLF
# (éditer sous Linux ou « LF » dans l’éditeur), puis redéployer. Vérifier DNS → IP du VPS.
TRAEFIK_HOST_RULE=Host(`vdev.dsp5-archi-o22a-15m-g3.fr`)

# Registre Harbor : projet GitHub « vdev » (créer le projet vdev dans Harbor)
REGISTRY=harbor.dsp5-archi-o22a-15m-g3.fr/vdev

# Renseigné par la CI au déploiement (SHA du commit)
IMAGE_TAG=replace-me

MONGO_ROOT_PASSWORD=change-me-root
MONGO_USER=thetiptop
MONGO_PASSWORD=thetiptop123

JWT_SECRET=change-me-jwt-vdev
CLIENT_URL=https://vdev.dsp5-archi-o22a-15m-g3.fr

# Comptes de démo : créés automatiquement en fin de job GitHub Actions (createAdmin.js).
# Par défaut : admin@thetiptop.fr / Admin123! — exécution manuelle si besoin :
# docker compose -f infra/deploy/docker-compose.stack.yml --env-file infra/deploy/env/vdev.env exec api node src/scripts/createAdmin.js
