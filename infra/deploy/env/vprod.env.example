COMPOSE_PROJECT_NAME=thetiptop-vprod

STACK_NAME=vprod

# Prod : URL publique = domaine racine uniquement (pas de sous-domaine vprod.)
# Traefik v3 : un seul Host(`…`). Guillemets recommandés si la ligne contient des caractères spéciaux.
TRAEFIK_HOST_RULE="Host(`dsp5-archi-o22a-15m-g3.fr`)"

# Projet Harbor « vprod »
REGISTRY=harbor.dsp5-archi-o22a-15m-g3.fr/vprod
# Remplacé automatiquement par le workflow « CD / vprod » (SHA du commit). En déploiement manuel :
# mettre un tag qui existe dans Harbor (ex. le SHA du dernier commit sur vprod), pas « replace-me ».
IMAGE_TAG=replace-me

MONGO_ROOT_PASSWORD=change-me-root-prod
MONGO_USER=thetiptop
MONGO_PASSWORD=change-me-mongo-prod

JWT_SECRET=change-me-jwt-prod
# URL canonique = racine du domaine (cookies / OAuth)
CLIENT_URL=https://dsp5-archi-o22a-15m-g3.fr

# EmailJS — à recopier dans le secret GitHub VPROD_ENV_FILE (ne pas committer vprod.env réel)
EMAILJS_SERVICE_ID=service_85ig8ef
EMAILJS_PUBLIC_KEY=3JGnaFOAoe2uCHoN9
EMAILJS_PRIVATE_KEY=6zhpXKcEp_BNzmOsfxZ6I
EMAILJS_TEMPLATE_NEWSLETTER_WELCOME=template_nqb8mem
EMAILJS_TEMPLATE_NEWSLETTER_GOODBYE=
EMAILJS_TEMPLATE_PRIZE_DELIVERED=

