# En CI : le fichier .env sur le VPS est créé par les workflows deploy-* via le secret
# MONITORING_GRAFANA_ADMIN_PASSWORD (ou MONITORING_ENV_FILE / MONITORING_ENV_FILE_B64).
# Copie locale uniquement pour tests : infra/monitoring/.env (non versionné, voir .gitignore).
# DNS : enregistrements A vers l’IP du VPS pour les deux hôtes.
# Les routes HTTPS Traefik sont dans infra/vps/traefik/dynamic/monitoring.yml — mêmes noms d’hôte que ci-dessous.
#
GRAFANA_HOST=grafana.dsp5-archi-o22a-15m-g3.fr
PROMETHEUS_HOST=prometheus.dsp5-archi-o22a-15m-g3.fr

# Changer le mot de passe avant exposition publique.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
