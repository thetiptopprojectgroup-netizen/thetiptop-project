services:
  traefik:
    image: {{ traefik_image }}
    container_name: traefik
    restart: unless-stopped
    # Docker Engine récent exige une API ≥ 1.40 ; forcer la négociation côté client Traefik.
    environment:
      DOCKER_API_VERSION: "{{ traefik_docker_api_version }}"
    security_opt:
      - no-new-privileges:true
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik_letsencrypt:/letsencrypt
      - {{ traefik_install_dir }}/dynamic:/etc/traefik/dynamic:ro
    command:
      - "--api.dashboard={{ traefik_dashboard_enabled | lower }}"
      - "--providers.file.directory=/etc/traefik/dynamic"
      - "--providers.file.watch=true"
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.docker.network=traefik_public"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      - "--certificatesresolvers.letsencrypt.acme.email={{ traefik_acme_email }}"
      - "--certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json"
      - "--certificatesresolvers.letsencrypt.acme.httpchallenge=true"
      - "--certificatesresolvers.letsencrypt.acme.httpchallenge.entrypoint=web"
    networks:
      - traefik_public

networks:
  traefik_public:
    external: true

volumes:
  traefik_letsencrypt:
