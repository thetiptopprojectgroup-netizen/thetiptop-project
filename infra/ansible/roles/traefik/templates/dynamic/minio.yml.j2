# Routage MinIO via provider fichier (contourne les soucis Traefik + API Docker sur certains Engine).
# Console sur le host « console » à la racine / (pas /console — évite page blanche du SPA).
{% set h_console = minio_traefik_hostname | default('') %}
{% set h_s3 = minio_s3_hostname | default('') %}
http:
  middlewares:
{% if h_console | length > 0 %}
    minio-legacy-console-redirect:
      redirectRegex:
        regex: "^https://{{ h_console | replace('.', '\\.') }}/console.*"
        replacement: "https://{{ h_console }}/"
        permanent: false
{% endif %}
  routers:
{% if h_console | length > 0 %}
    minio-console-legacy-path:
      rule: "Host(`{{ h_console }}`) && PathPrefix(`/console`)"
      entryPoints:
        - websecure
      middlewares:
        - minio-legacy-console-redirect
      service: noop@internal
      tls:
        certResolver: le
      priority: 200
{% endif %}
{% if h_console | length > 0 %}
    minio-console-file:
      rule: "Host(`{{ h_console }}`)"
      entryPoints:
        - websecure
      service: minio-console-file-svc
      tls:
        certResolver: le
      priority: 10
{% endif %}
{% if h_s3 | length > 0 %}
    minio-s3-file:
      rule: "Host(`{{ h_s3 }}`)"
      entryPoints:
        - websecure
      service: minio-s3-file-svc
      tls:
        certResolver: le
      priority: 10
{% endif %}
  services:
{% if h_console | length > 0 %}
    minio-console-file-svc:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: "http://thetiptop-minio:9001"
{% endif %}
{% if h_s3 | length > 0 %}
    minio-s3-file-svc:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: "http://thetiptop-minio:9000"
{% endif %}
