# Route Harbor sans provider Docker (contournement si Docker Engine refuse l’API client Traefik).
# Le conteneur {{ traefik_harbor_backend }} doit être sur le réseau traefik (même que Traefik).
http:
  routers:
    harbor-file:
      rule: "Host(`{{ traefik_harbor_hostname }}`)"
      entryPoints:
        - websecure
      service: harbor-file-svc
      tls:
        certResolver: le
      priority: 200
  services:
    harbor-file-svc:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: "http://{{ traefik_harbor_backend }}:8080"
