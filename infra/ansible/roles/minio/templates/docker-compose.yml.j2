services:
  minio:
    image: {{ minio_image }}
    container_name: thetiptop-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: "{{ minio_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ minio_root_password }}"
    volumes:
      - "{{ minio_data_path }}:/data"
    ports:
      - "9000:9000"
      - "9001:9001"
