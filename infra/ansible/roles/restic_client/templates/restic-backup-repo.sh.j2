#!/usr/bin/env bash
# Backup one Restic repository and create MongoDB dump.
set -euo pipefail

RESTIC_REPOSITORY="${1:?Missing arg #1: Restic repository URL}"
ENV_FILE="${2:?Missing arg #2: deploy env file path}"
ENV_NAME="${3:-default}"
ON_CHANGE_ONLY="${ON_CHANGE_ONLY:-0}"
SKIP_FORGET_PRUNE="${SKIP_FORGET_PRUNE:-0}"

export RESTIC_REPOSITORY
export RESTIC_PASSWORD="{{ restic_password }}"
export AWS_ACCESS_KEY_ID="{{ minio_root_user }}"
export AWS_SECRET_ACCESS_KEY="{{ minio_root_password }}"
export AWS_DEFAULT_REGION="{{ restic_aws_default_region | default('us-east-1') }}"
export RESTIC_PROGRESS_FPS=0

log() { echo "$(date -Is) ${RESTIC_REPOSITORY} - $*"; }

if [[ ! -f "${ENV_FILE}" ]]; then
  log "ERROR: env file not found: ${ENV_FILE}"
  exit 1
fi

read_env() {
  local key="$1"
  local default_value="$2"
  local value

  value="$(awk -F= -v k="$key" '$1==k {print substr($0, index($0, "=")+1)}' "${ENV_FILE}" | tail -n 1)"
  value="${value%$'\r'}"
  value="${value%\"}"
  value="${value#\"}"
  if [[ -n "${value}" ]]; then
    printf "%s\n" "${value}"
  else
    printf "%s\n" "${default_value}"
  fi
}

COMPOSE_PROJECT_NAME="$(read_env COMPOSE_PROJECT_NAME "thetiptop-${ENV_NAME}")"
MONGO_USER="$(read_env MONGO_USER "thetiptop")"
MONGO_PASSWORD="$(read_env MONGO_PASSWORD "thetiptop123")"
MONGO_DB="$(read_env MONGO_DB "thetiptop")"
MONGO_AUTH_DB="$(read_env MONGO_AUTH_DB "thetiptop")"
MONGO_HOST="${COMPOSE_PROJECT_NAME}-mongodb-1"

BACKUP_ROOT="/opt/thetiptop/backup/mongodb/${ENV_NAME}"
SIG_FILE="${BACKUP_ROOT}/.last-db-signature"
TS="$(date +%Y%m%d-%H%M%S)"
DUMP_BASENAME="mongodump-${TS}.archive.gz"

mkdir -p "${BACKUP_ROOT}"

DB_SIGNATURE="$(
  docker run --rm \
    --network "${COMPOSE_PROJECT_NAME}_internal" \
    mongo:7.0 mongosh --quiet \
      --host "${MONGO_HOST}" \
      --port 27017 \
      --username "${MONGO_USER}" \
      --password "${MONGO_PASSWORD}" \
      --authenticationDatabase "${MONGO_AUTH_DB}" \
      "${MONGO_DB}" \
      --eval "const s=db.stats(); print([s.objects,s.dataSize,s.storageSize,s.indexSize].join(':'))" \
    2>/dev/null || true
)"

if [[ "${ON_CHANGE_ONLY}" == "1" && -f "${SIG_FILE}" ]]; then
  LAST_SIG="$(cat "${SIG_FILE}" || true)"
  if [[ -n "${DB_SIGNATURE}" && "${DB_SIGNATURE}" == "${LAST_SIG}" ]]; then
    log "No DB change detected, skipping backup."
    exit 0
  fi
fi

log "Create mongodump: ${BACKUP_ROOT}/${DUMP_BASENAME}"
docker run --rm \
  --user 0:0 \
  --network "${COMPOSE_PROJECT_NAME}_internal" \
  -v "${BACKUP_ROOT}:/backup" \
  mongo:7.0 mongodump \
    --host "${MONGO_HOST}" \
    --port 27017 \
    --username "${MONGO_USER}" \
    --password "${MONGO_PASSWORD}" \
    --authenticationDatabase "${MONGO_AUTH_DB}" \
    --db "${MONGO_DB}" \
    --archive="/backup/${DUMP_BASENAME}" \
    --gzip

# Keep last 30 dumps per environment.
ls -1t "${BACKUP_ROOT}"/mongodump-*.archive.gz 2>/dev/null | tail -n +31 | xargs -r rm -f
if [[ -n "${DB_SIGNATURE}" ]]; then
  printf "%s\n" "${DB_SIGNATURE}" > "${SIG_FILE}"
fi

if ! /usr/local/bin/restic snapshots >/dev/null 2>&1; then
  log "Init Restic repository."
  /usr/local/bin/restic init
fi

log "Run restic backup."
/usr/local/bin/restic backup /opt/thetiptop --tag ansible \
  --exclude "{{ minio_data_path }}" \
  --exclude "{{ harbor_data_volume }}"

if [[ "${SKIP_FORGET_PRUNE}" != "1" ]]; then
  log "Run restic forget/prune."
  /usr/local/bin/restic forget --keep-daily 7 --keep-weekly 4 --prune || log "WARN: forget/prune failed"
else
  log "Skip forget/prune in watch mode."
fi

log "OK"
