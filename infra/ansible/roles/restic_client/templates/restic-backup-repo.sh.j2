#!/usr/bin/env bash
# Sauvegarde /opt/thetiptop vers un seul dépôt (URL passée en $1 — utilisé par cron).
# Génère d'abord un mongodump dans /opt/thetiptop/backup/mongodb/<env>.
set -euo pipefail
RESTIC_REPOSITORY="${1:?Argument requis : URL s3 du dépôt restic}"
ENV_FILE="${2:?Argument requis : fichier d'environnement deploy (*.env)}"
ENV_NAME="${3:-default}"
export RESTIC_REPOSITORY
export RESTIC_PASSWORD="{{ restic_password }}"
export AWS_ACCESS_KEY_ID="{{ minio_root_user }}"
export AWS_SECRET_ACCESS_KEY="{{ minio_root_password }}"
export AWS_DEFAULT_REGION="{{ restic_aws_default_region | default('us-east-1') }}"
export RESTIC_PROGRESS_FPS=0

log() { echo "$(date -Is) $RESTIC_REPOSITORY — $*"; }

if [[ ! -f "$ENV_FILE" ]]; then
  log "ERREUR: fichier env introuvable: $ENV_FILE"
  exit 1
fi

# shellcheck disable=SC1090
set -a
source "$ENV_FILE"
set +a

COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-thetiptop-$ENV_NAME}"
MONGO_USER="${MONGO_USER:-thetiptop}"
MONGO_PASSWORD="${MONGO_PASSWORD:-thetiptop}"
MONGO_DB="${MONGO_DB:-thetiptop}"
MONGO_AUTH_DB="${MONGO_AUTH_DB:-thetiptop}"
MONGO_CONTAINER="${COMPOSE_PROJECT_NAME}-mongodb-1"

BACKUP_ROOT="/opt/thetiptop/backup/mongodb/$ENV_NAME"
mkdir -p "$BACKUP_ROOT"
TS="$(date +%Y%m%d-%H%M%S)"
DUMP_FILE="$BACKUP_ROOT/mongodump-$TS.archive.gz"

MONGO_IP="$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "$MONGO_CONTAINER" 2>/dev/null || true)"
if [[ -z "$MONGO_IP" ]]; then
  log "ERREUR: impossible de trouver l'IP du conteneur Mongo: $MONGO_CONTAINER"
  exit 1
fi

log "mongodump via conteneur mongo:7.0 vers $DUMP_FILE"
docker run --rm \
  --network "${COMPOSE_PROJECT_NAME}_internal" \
  -v "$BACKUP_ROOT:/backup" \
  mongo:7.0 \
  bash -lc "mongodump \
    --host '$MONGO_IP' \
    --port 27017 \
    --username '$MONGO_USER' \
    --password '$MONGO_PASSWORD' \
    --authenticationDatabase '$MONGO_AUTH_DB' \
    --db '$MONGO_DB' \
    --archive='/backup/mongodump-$TS.archive.gz' \
    --gzip"

# Conserver les 30 derniers dumps par environnement pour éviter la croissance infinie.
ls -1t "$BACKUP_ROOT"/mongodump-*.archive.gz 2>/dev/null | tail -n +31 | xargs -r rm -f

if ! /usr/local/bin/restic snapshots >/dev/null 2>&1; then
  log "restic init"
  /usr/local/bin/restic init
fi

log "restic backup…"
/usr/local/bin/restic backup /opt/thetiptop --tag ansible \
  --exclude "{{ minio_data_path }}" \
  --exclude "{{ harbor_data_volume }}"

log "restic forget / prune…"
/usr/local/bin/restic forget --keep-daily 7 --keep-weekly 4 --prune || log "ATTENTION : forget/prune a échoué"
log "OK"
