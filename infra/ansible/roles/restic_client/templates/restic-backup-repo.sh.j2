#!/usr/bin/env bash
# Backup one Restic repository and create MongoDB dump.
set -euo pipefail

RESTIC_REPOSITORY="${1:?Missing arg #1: Restic repository URL}"
ENV_FILE="${2:?Missing arg #2: deploy env file path}"
ENV_NAME="${3:-default}"
ON_CHANGE_ONLY="${ON_CHANGE_ONLY:-0}"
SKIP_FORGET_PRUNE="${SKIP_FORGET_PRUNE:-0}"

export RESTIC_REPOSITORY
export RESTIC_PASSWORD="{{ restic_password }}"
export AWS_ACCESS_KEY_ID="{{ minio_root_user }}"
export AWS_SECRET_ACCESS_KEY="{{ minio_root_password }}"
export AWS_DEFAULT_REGION="{{ restic_aws_default_region | default('us-east-1') }}"
export RESTIC_PROGRESS_FPS=0

log() { echo "$(date -Is) ${RESTIC_REPOSITORY} - $*"; }

# Jour de la semaine en français (date +%u : 1=lundi … 7=dimanche), fuseau BACKUP_DUMP_TZ.
jour_semaine_fr() {
  case "$(TZ="${BACKUP_DUMP_TZ:-Europe/Paris}" date +%u)" in
    1) printf '%s' "lundi" ;;
    2) printf '%s' "mardi" ;;
    3) printf '%s' "mercredi" ;;
    4) printf '%s' "jeudi" ;;
    5) printf '%s' "vendredi" ;;
    6) printf '%s' "samedi" ;;
    7) printf '%s' "dimanche" ;;
    *) printf '%s' "inconnu" ;;
  esac
}

if [[ ! -f "${ENV_FILE}" ]]; then
  log "ERROR: env file not found: ${ENV_FILE}"
  exit 1
fi

read_env() {
  local key="$1"
  local default_value="$2"
  local value

  value="$(awk -F= -v k="$key" '$1==k {print substr($0, index($0, "=")+1)}' "${ENV_FILE}" | tail -n 1)"
  value="${value%$'\r'}"
  value="${value%\"}"
  value="${value#\"}"
  if [[ -n "${value}" ]]; then
    printf "%s\n" "${value}"
  else
    printf "%s\n" "${default_value}"
  fi
}

COMPOSE_PROJECT_NAME="$(read_env COMPOSE_PROJECT_NAME "thetiptop-${ENV_NAME}")"
MONGO_USER="$(read_env MONGO_USER "thetiptop")"
MONGO_PASSWORD="$(read_env MONGO_PASSWORD "thetiptop123")"
MONGO_DB="$(read_env MONGO_DB "thetiptop")"
MONGO_AUTH_DB="$(read_env MONGO_AUTH_DB "thetiptop")"
MONGO_HOST="${COMPOSE_PROJECT_NAME}-mongodb-1"

BACKUP_ROOT="/opt/thetiptop/backup/mongodb/${ENV_NAME}"
SIG_FILE="${BACKUP_ROOT}/.last-db-signature"
# Ex. mongodump_dimanche_12_04_2026_13_45_08_48291.gz — date/heure en Europe/Paris (pas l’UTC du serveur).
BACKUP_DUMP_TZ="Europe/Paris"
DUMP_DATE="$(TZ="${BACKUP_DUMP_TZ}" date +%d_%m_%Y)"
DUMP_TIME="$(TZ="${BACKUP_DUMP_TZ}" date +%H_%M_%S)"
RAND5="$(printf '%05d' "$(( (RANDOM * 32768 + RANDOM) % 100000 ))")"
DUMP_BASENAME="mongodump_$(jour_semaine_fr)_${DUMP_DATE}_${DUMP_TIME}_${RAND5}.gz"

mkdir -p "${BACKUP_ROOT}"
# Bind mount : en Docker rootless, l’UID 0 du conteneur n’est pas root sur l’hôte — sans ça, « permission denied » sur /backup/….
# SELinux (CentOS/RHEL) : le label :z permet l’écriture depuis le conteneur.
chmod 0777 "${BACKUP_ROOT}" 2>/dev/null || true

# Empreinte stable (collections / objects / indexes) — moins de variation fantôme que dataSize/storageSize.
DB_SIGNATURE="$(
  docker run --rm \
    --network "${COMPOSE_PROJECT_NAME}_internal" \
    mongo:7.0 mongosh --quiet \
      --host "${MONGO_HOST}" \
      --port 27017 \
      --username "${MONGO_USER}" \
      --password "${MONGO_PASSWORD}" \
      --authenticationDatabase "${MONGO_AUTH_DB}" \
      "${MONGO_DB}" \
      --eval "const s=db.stats(); const c=s.collections!=null?s.collections:0; const i=s.indexes!=null?s.indexes:0; print([c,s.objects||0,i].join(':'))" \
    2>/dev/null || true
)"
DB_SIGNATURE="$(printf '%s' "${DB_SIGNATURE}" | tr -d '\r\n' | sed 's/[[:space:]]*$//')"

if [[ "${ON_CHANGE_ONLY}" == "1" ]]; then
  if [[ -z "${DB_SIGNATURE}" ]]; then
    log "ERROR: empreinte Mongo vide — mongosh indisponible ou mauvais identifiants/réseau (host=${MONGO_HOST}, projet=${COMPOSE_PROJECT_NAME}). Pas de dump pour éviter une boucle sans fichier."
    exit 1
  fi
  if [[ -f "${SIG_FILE}" ]]; then
    LAST_SIG="$(tr -d '\r\n' < "${SIG_FILE}" || true)"
    if [[ "${DB_SIGNATURE}" == "${LAST_SIG}" ]]; then
      log "No DB change detected, skipping backup."
      exit 0
    fi
  fi
fi

DUMP_PATH="${BACKUP_ROOT}/${DUMP_BASENAME}"
docker run --rm \
  --user 0:0 \
  --network "${COMPOSE_PROJECT_NAME}_internal" \
  -v "${BACKUP_ROOT}:/backup:rw,z" \
  mongo:7.0 mongodump \
    --host "${MONGO_HOST}" \
    --port 27017 \
    --username "${MONGO_USER}" \
    --password "${MONGO_PASSWORD}" \
    --authenticationDatabase "${MONGO_AUTH_DB}" \
    --db "${MONGO_DB}" \
    --archive="/backup/${DUMP_BASENAME}" \
    --gzip

if [[ ! -f "${DUMP_PATH}" ]]; then
  log "ERROR: mongodump terminé mais fichier absent : ${DUMP_PATH}"
  exit 1
fi
log "mongodump OK ($(du -h "${DUMP_PATH}" | awk '{print $1}')) : ${DUMP_PATH}"

# Garder les 30 derniers dumps (ne pas appeler ls sans fichier : avec nullglob, ls seul listerait le cwd).
if compgen -G "${BACKUP_ROOT}/mongodump_*.gz" >/dev/null 2>&1; then
  ls -1t "${BACKUP_ROOT}"/mongodump_*.gz | tail -n +31 | xargs -r rm -f
fi

printf '%s\n' "${DB_SIGNATURE}" > "${SIG_FILE}"

if ! /usr/local/bin/restic snapshots >/dev/null 2>&1; then
  log "Init Restic repository."
  /usr/local/bin/restic init
fi

log "Run restic backup."
/usr/local/bin/restic backup /opt/thetiptop --tag ansible \
  --exclude "{{ minio_data_path }}" \
  --exclude "{{ harbor_data_volume }}"

if [[ "${SKIP_FORGET_PRUNE}" != "1" ]]; then
  log "Run restic forget/prune."
  /usr/local/bin/restic forget --keep-daily 7 --keep-weekly 4 --prune || log "WARN: forget/prune failed"
else
  log "Skip forget/prune in watch mode."
fi

log "OK"
