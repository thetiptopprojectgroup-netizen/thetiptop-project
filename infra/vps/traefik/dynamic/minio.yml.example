# Référence : le fichier versionné est minio.yml (sans .example).
# Déploiement sans SSH manuel : push Git → GitHub Actions exécute infra/deploy/apply-traefik-minio-from-app.sh.
#
# Console à la racine du host minio (pas /console + StripPrefix → SPA cassée).
# Les URLs /console/* redirigent vers /.

http:
  middlewares:
    minio-legacy-console-redirect:
      redirectRegex:
        regex: "^https://minio\\.dsp5-archi-o22a-15m-g3\\.fr/console.*"
        replacement: "https://minio.dsp5-archi-o22a-15m-g3.fr/"
        permanent: false
  routers:
    minio-console-legacy-path:
      rule: "Host(`minio.dsp5-archi-o22a-15m-g3.fr`) && PathPrefix(`/console`)"
      entryPoints:
        - websecure
      middlewares:
        - minio-legacy-console-redirect
      service: noop@internal
      tls:
        certResolver: le
      priority: 200
    minio-console-file:
      rule: "Host(`minio.dsp5-archi-o22a-15m-g3.fr`)"
      entryPoints:
        - websecure
      service: minio-console-file-svc
      tls:
        certResolver: le
      priority: 10
    minio-s3-file:
      rule: "Host(`restic.dsp5-archi-o22a-15m-g3.fr`)"
      entryPoints:
        - websecure
      service: minio-s3-file-svc
      tls:
        certResolver: le
      priority: 10
  services:
    minio-console-file-svc:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: "http://thetiptop-minio:9001"
    minio-s3-file-svc:
      loadBalancer:
        passHostHeader: true
        servers:
          - url: "http://thetiptop-minio:9000"
