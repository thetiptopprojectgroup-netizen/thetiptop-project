# En CI : le fichier .env sur le VPS est créé par les workflows deploy-* via
# LOGGING_ELASTIC_PASSWORD (ou LOGGING_ENV_FILE / LOGGING_ENV_FILE_B64).
# Copie locale : infra/logging/.env (non versionné).
#
# Connexion Kibana : utilisateur « admin » (créé automatiquement), mot de passe = KIBANA_PASSWORD.
# DNS : enregistrement A vers l’IP du VPS (même FQDN que la règle Host sur le service kibana → labels Traefik).
#
KIBANA_HOST=kibana.dsp5-archi-o22a-15m-g3.fr
ELASTIC_PASSWORD=changeme
KIBANA_USERNAME=admin
KIBANA_PASSWORD=changeme-admin
