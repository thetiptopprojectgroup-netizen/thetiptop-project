{
  "name": "thetiptop-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-seo.js",
    "build": "vite build && vite build --ssr src/entry-server.jsx --outDir dist/server",
    "start": "node server.mjs",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "test:unit": "jest --config jest.config.cjs --passWithNoTests --coverage=false --testPathIgnorePatterns=/src/test/integration/",
    "test:integration": "jest --config jest.config.cjs --passWithNoTests --coverage=false --testPathPatterns=src/test/integration",
    "test:functional": "playwright test",
    "test:e2e": "playwright test",
    "test:coverage": "jest --config jest.config.cjs --coverage --passWithNoTests",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:functional"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.6",
    "express": "^5.2.1",
    "framer-motion": "^10.17.4",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.49.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.21.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "babel-jest": "^30.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8"
  }
}
